# SPDX-PackageName: senpai
#
# Create the secret:
#   kubectl create secret generic senpai-secrets \
#     --from-literal=wandb-api-key=YOUR_KEY \
#     --from-literal=anthropic-api-key=YOUR_KEY

apiVersion: v1
kind: Secret
metadata:
  name: senpai-secrets
type: Opaque
stringData:
  wandb-api-key: "REPLACE_ME"
  anthropic-api-key: "REPLACE_ME"
